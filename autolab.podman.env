# AutoLab Podman environment
# Copy to autolab.podman.env.local and set AUTOLAB_GATEWAY_TOKEN (or use -e when running).
# This file can be used with:
#   AUTOLAB_PODMAN_ENV=/path/to/autolab.podman.env ./scripts/run-autolab-podman.sh launch

# Required: gateway auth token. Generate with: openssl rand -hex 32
# Set this before running the container (or use run-autolab-podman.sh which can generate it).
AUTOLAB_GATEWAY_TOKEN=

# Optional: web provider (leave empty to skip)
# CLAUDE_AI_SESSION_KEY=
# CLAUDE_WEB_SESSION_KEY=
# CLAUDE_WEB_COOKIE=

# Host port mapping (defaults; override if needed)
AUTOLAB_PODMAN_GATEWAY_HOST_PORT=18789
AUTOLAB_PODMAN_BRIDGE_HOST_PORT=18790

# Gateway bind (used by the launch script)
AUTOLAB_GATEWAY_BIND=lan

# Optional: LLM provider API keys (for zero cost use Ollama locally or Groq free tier)
# OLLAMA_API_KEY=ollama-local
# GROQ_API_KEY=
